# Scraper Agent — Environment Configuration
# Copy this to .env and fill in your values
# NEVER commit .env to git

# ── LLM Backend ───────────────────────────────────────────────
# Options: ollama | openclaw | anthropic | openai | none
LLM_BACKEND=ollama

# Ollama (free, local) — https://ollama.ai
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# Anthropic Claude (optional)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# OpenAI (optional)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ── Optional Data Source API Keys ─────────────────────────────
# Scraping works without these — they unlock higher rate limits
YOUTUBE_API_KEY=
COINMARKETCAP_API_KEY=
ALPHA_VANTAGE_API_KEY=

# ── Output Settings ───────────────────────────────────────────
OUTPUT_DIR=./output
OUTPUT_FORMAT=json
CACHE_DIR=./.cache

# ── Dashboard ─────────────────────────────────────────────────
DASHBOARD_DIR=./dashboard
DASHBOARD_PORT=8080
